# ── GLM API (ZhipuAI / Z.ai) ──
# Get your API key from https://open.bigmodel.cn or https://z.ai
# The API is OpenAI-compatible (uses /chat/completions format)
# Available models: glm-4.7, glm-4.6, glm-5, glm-4-plus
GLM_API_KEY=your-glm-api-key-here
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4.7
GLM_EMBEDDING_MODEL=embedding-3

# ── Database ──
POSTGRES_DB=texttosql
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@db:5432/texttosql

# ── RAG ──
CHROMA_PERSIST_DIR=/app/chroma_data
RAG_TOP_K=10

# ── App ──
MAX_RESULT_ROWS=1000
RATE_LIMIT_PER_MINUTE=20

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost/api
